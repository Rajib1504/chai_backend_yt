CLIENT_URL= client url 
MONGO_URI= db connection string
PORT= port number

ACCESS_TOKEN_EXPIRE= access token expire time
REFRESH_TOKEN_EXPIRE= refresh token expire time
JWT_ACCESS_SECRET= access token secret key
JWT_REFRESH_SECRET= refresh token secret key
// for generate the secreate use this comand in terminal : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"



CLOUDINARY_CLOUD_NAME= my_cloud_name
CLOUDINARY_API_KEY= my_key
CLOUDINARY_API_SECRET= my_secret
